---
import { render } from "astro:content";
import DocLayout from "@/layouts/doc-layout.astro";
import Note from "@/components/admonitions/note.astro";
import Tip from "@/components/admonitions/tip.astro";
import Info from "@/components/admonitions/info.astro";
import Warning from "@/components/admonitions/warning.astro";
import Danger from "@/components/admonitions/danger.astro";
import CategoryNav from "@/components/category-nav.astro";
import NavCardGrid from "@/components/nav-card-grid.astro";
import Tabs from "@/components/tabs.astro";
import TabItem from "@/components/tab-item.astro";
import Details from "@/components/details.astro";
import Breadcrumb from "@/components/breadcrumb.astro";
import { toRouteSlug } from "@/utils/slug";
import { buildNavTree, buildBreadcrumbs, flattenTree, findNode, collectAutoIndexNodes } from "@/utils/docs";
import type { Heading } from "@/types/heading";
import { getNavSectionForSlug, getNavSubtree } from "@/utils/nav-scope";
import { t, getContentDir } from "@/config/i18n";
import EditLink from "@/components/edit-link.astro";
import { settings } from "@/config/settings";
import DocMetainfo from "@/components/doc-metainfo.astro";
import DocTags from "@/components/doc-tags.astro";
import { loadLocaleDocs } from "@/utils/locale-docs";

export async function getStaticPaths() {
  const { allDocs, fallbackSlugs, categoryMeta } = await loadLocaleDocs("ja");

  // Exclude unlisted pages from nav tree
  const navDocs = allDocs.filter((doc) => !doc.data.unlisted);
  const tree = buildNavTree(navDocs, "ja", categoryMeta);

  // Regular doc pages
  const docPaths = allDocs.map((entry) => {
    const slug = entry.data.slug ?? toRouteSlug(entry.id);
    const isFallback = fallbackSlugs.has(slug);
    const navSection = getNavSectionForSlug(slug);
    const subtree = getNavSubtree(tree, navSection);
    const flat = flattenTree(subtree);
    const idx = flat.findIndex((n) => n.slug === slug);

    let prevNode = idx > 0 ? flat[idx - 1] : null;
    let nextNode = idx >= 0 && idx < flat.length - 1 ? flat[idx + 1] : null;

    // Apply frontmatter overrides
    if (entry.data.pagination_prev !== undefined) {
      if (entry.data.pagination_prev === null) {
        prevNode = null;
      } else {
        const found = findNode(tree, entry.data.pagination_prev);
        prevNode = found ?? prevNode;
      }
    }
    if (entry.data.pagination_next !== undefined) {
      if (entry.data.pagination_next === null) {
        nextNode = null;
      } else {
        const found = findNode(tree, entry.data.pagination_next);
        nextNode = found ?? nextNode;
      }
    }

    // Find this node's children for auto CategoryNav on index pages
    const node = findNode(tree, slug);
    const navChildren = node?.children.filter((c) => c.hasPage || c.children.length > 0) ?? [];

    return {
      params: { slug },
      props: {
        entry,
        contentDir: isFallback ? settings.docsDir : getContentDir("ja"),
        isFallback,
        breadcrumbs: buildBreadcrumbs(tree, slug, "ja"),
        prev: prevNode,
        next: nextNode,
        navChildren,
      },
    };
  });

  // Auto-generated index pages for categories without index.mdx
  const autoIndexPaths = collectAutoIndexNodes(tree).map((node) => ({
    params: { slug: node.slug },
    props: {
      entry: null,
      contentDir: getContentDir("ja"),
      isFallback: false,
      autoIndex: node,
      breadcrumbs: buildBreadcrumbs(tree, node.slug, "ja"),
      prev: null,
      next: null,
    },
  }));

  return [...docPaths, ...autoIndexPaths];
}

const { entry, contentDir, isFallback, breadcrumbs = [], prev, next, autoIndex, navChildren = [] } = Astro.props;

const components = { Note, Tip, Info, Warning, Danger, CategoryNav, Tabs, TabItem, Details };

let Content: any;
let headings: Heading[] = [];

if (entry) {
  const rendered = await render(entry as any);
  Content = rendered.Content;
  headings = rendered.headings;
}

const slug = autoIndex ? autoIndex.slug : (entry!.data.slug ?? toRouteSlug(entry!.id));
---

<DocLayout
  title={autoIndex ? autoIndex.label : entry.data.title}
  description={autoIndex ? autoIndex.description : entry.data.description}
  lang="ja"
  currentSlug={slug}
  headings={autoIndex ? [] : headings}
  unlisted={entry?.data?.unlisted}
>
  <Breadcrumb slot="breadcrumb" items={breadcrumbs} />
  {autoIndex ? (
    <Fragment>
      <h1 class="text-heading font-bold mb-vsp-xs">{autoIndex.label}</h1>
      {autoIndex.description && (
        <p class="mt-0 mb-vsp-lg text-subheading text-muted">{autoIndex.description}</p>
      )}
      <NavCardGrid children={autoIndex.children} locale="ja" />
    </Fragment>
  ) : (
    <Fragment>
      <h1 class="text-heading font-bold mb-vsp-xs">{entry.data.title}</h1>
      <DocMetainfo filePath={`${contentDir}/${entry.id}`} locale="ja" />

      {isFallback && (
        <div class="mb-vsp-md border border-info/30 bg-info/5 px-hsp-lg py-vsp-sm text-small text-muted rounded" role="note">
          {t("doc.fallbackNotice", "ja")}
        </div>
      )}

      {entry.data.description && (
        <p class="mt-0 mb-vsp-lg text-subheading text-muted">{entry.data.description}</p>
      )}

      {entry?.data?.tags && <DocTags tags={entry.data.tags} locale="ja" />}

      <Content components={components} />

      <NavCardGrid children={navChildren} locale="ja" class="mt-vsp-lg mb-vsp-md" />

      {settings.editUrl && entry && (
        <div class="mt-vsp-xl mb-vsp-md border-t border-muted pt-vsp-md">
          <EditLink contentDir={contentDir} entryId={entry.id} locale="ja" />
        </div>
      )}

      <nav class="mt-vsp-2xl grid grid-cols-2 gap-hsp-xl">
        {prev ? (
          <a href={prev.href} class="group border border-muted rounded-lg p-hsp-lg hover:border-accent">
            <div class="flex items-center gap-hsp-xs text-caption text-muted mb-vsp-2xs">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-[0.75rem] w-[0.75rem]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
              </svg>
              <span>{t("nav.previous", "ja")}</span>
            </div>
            <p class="text-small font-semibold group-hover:text-accent">{prev.label}</p>
          </a>
        ) : <div />}
        {next ? (
          <a href={next.href} class="group border border-muted rounded-lg p-hsp-lg hover:border-accent text-right">
            <div class="flex items-center justify-end gap-hsp-xs text-caption text-muted mb-vsp-2xs">
              <span>{t("nav.next", "ja")}</span>
              <svg xmlns="http://www.w3.org/2000/svg" class="h-[0.75rem] w-[0.75rem]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
              </svg>
            </div>
            <p class="text-small font-semibold group-hover:text-accent">{next.label}</p>
          </a>
        ) : <div />}
      </nav>
    </Fragment>
  )}
</DocLayout>
