---
import TailwindPreview from "./tailwind-preview/tailwind-preview";

interface Props {
  html: string;
  css?: string;
  title?: string;
  height?: number;
  defaultOpen?: boolean;
  plugins?: string[];
}

const { html, css, title, height, defaultOpen, plugins } = Astro.props;
---

<TailwindPreview
  client:visible
  html={html}
  css={css}
  title={title}
  height={height}
  defaultOpen={defaultOpen}
  plugins={plugins}
/>
