---
import CssPreview from "./css-preview/css-preview";

interface Props {
  html: string;
  css: string;
  title?: string;
  height?: number;
  defaultOpen?: boolean;
}

const { html, css, title, height, defaultOpen } = Astro.props;
---

<CssPreview
  client:visible
  html={html}
  css={css}
  title={title}
  height={height}
  defaultOpen={defaultOpen}
/>
