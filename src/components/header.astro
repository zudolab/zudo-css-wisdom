---
import SidebarToggle from "@/components/sidebar-toggle";
import HeaderNav from "@/components/header-nav";
import ThemeToggle from "@/components/theme-toggle";
import LanguageSwitcher from "@/components/language-switcher.astro";
import VersionSwitcher from "@/components/version-switcher.astro";
import Search from "@/components/search.astro";
import { settings } from "@/config/settings";
import { withBase, stripBase } from "@/utils/base";
import { defaultLocale, locales, t, type Locale } from "@/config/i18n";
import type { VersionAvailability } from "@/utils/version-availability";

interface Props {
  lang?: Locale;
  currentPath?: string;
  currentVersion?: string;
  currentSlug?: string;
  versionAvailability?: VersionAvailability;
}

const {
  lang,
  currentPath = "",
  currentVersion,
  currentSlug,
  versionAvailability,
} = Astro.props;
const isNonDefaultLocale = lang != null && lang !== defaultLocale;
const pathWithoutBase = stripBase(currentPath);
const pathForMatch = isNonDefaultLocale
  ? pathWithoutBase.replace(new RegExp(`^/${lang}`), "")
  : pathWithoutBase;

// Prepare nav items for the React overflow-aware component
const activeNavPath = settings.headerNav
  .filter((item) => pathForMatch.startsWith(item.path))
  .sort((a, b) => b.path.length - a.path.length)[0]?.path;

const navItems = settings.headerNav.map((item) => ({
  label: item.labelKey ? t(item.labelKey, lang) : item.label,
  href: withBase(isNonDefaultLocale ? `/${lang}${item.path}` : item.path),
  isActive: item.path === activeNavPath,
}));
---

<header
  class="sticky top-0 z-50 flex h-[3.5rem] items-center border-b border-muted bg-surface px-hsp-lg"
>
  <SidebarToggle client:media="(max-width: 1023px)">
    <slot name="sidebar" />
  </SidebarToggle>

  <a
    href={withBase(isNonDefaultLocale ? `/${lang}/` : "/")}
    class="whitespace-nowrap text-subheading font-futura text-fg hover:underline focus:underline"
  >
    {settings.siteName}
  </a>

  <HeaderNav items={navItems} client:load />

  <div class="ml-auto flex items-center gap-x-hsp-md">
    {
      settings.versions && currentSlug && (
        <div class="hidden lg:block">
          <VersionSwitcher
            currentVersion={currentVersion}
            currentSlug={currentSlug}
            lang={lang}
            availability={versionAvailability}
            idSuffix="header"
          />
        </div>
      )
    }
    {
      settings.colorTweakPanel && (
        <button
          id="color-tweak-trigger"
          type="button"
          class="flex items-center justify-center text-muted transition-colors hover:text-fg"
          aria-label="Toggle color tweak panel"
          onclick="window.dispatchEvent(new CustomEvent('toggle-color-tweak-panel'))"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <circle cx="13.5" cy="6.5" r="2.5" />
            <circle cx="17.5" cy="10.5" r="2.5" />
            <circle cx="8.5" cy="7.5" r="2.5" />
            <circle cx="6.5" cy="12.5" r="2.5" />
            <path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10c.926 0 1.648-.746 1.648-1.688 0-.437-.18-.835-.437-1.125-.29-.289-.438-.652-.438-1.125a1.64 1.64 0 0 1 1.668-1.668h1.996c3.051 0 5.555-2.503 5.555-5.554C21.965 6.012 17.461 2 12 2z" />
          </svg>
        </button>
      )
    }
    {
      settings.aiAssistant && (
        <button
          id="ai-chat-trigger"
          type="button"
          class="flex items-center justify-center text-muted transition-colors hover:text-fg"
          aria-label="Open AI assistant"
          onclick="window.dispatchEvent(new CustomEvent('toggle-ai-chat'))"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="currentColor"
            aria-hidden="true"
          >
            <path d="M9.5 2.5Q10.5 11.5 18 13Q10.5 14.5 9.5 23.5Q8.5 14.5 1 13Q8.5 11.5 9.5 2.5Z" />
            <path d="M19 0.5Q19.5 4 23.5 5Q19.5 6 19 9.5Q18.5 6 14.5 5Q18.5 4 19 0.5Z" />
          </svg>
        </button>
      )
    }
    <a
      href="https://github.com/zudolab/zudo-css-wisdom"
      class="flex items-center justify-center text-muted transition-colors hover:text-fg"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="GitHub"
    >
      <svg viewBox="0 0 16 16" aria-hidden="true" class="w-[20px] h-[20px]">
        <path
          fill="currentColor"
          d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"
        ></path>
      </svg>
    </a>
    <Search />
    <div class="hidden lg:flex items-center gap-x-hsp-md">
      {
        settings.colorMode && (
          <ThemeToggle
            defaultMode={settings.colorMode.defaultMode}
            client:load
          />
        )
      }
      {lang && locales.length > 1 && <LanguageSwitcher lang={lang} />}
    </div>
  </div>
</header>
