{
  "name": "zudo-css-wisdom",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "predev": "lsof -ti :8811 | xargs kill 2>/dev/null; true",
    "dev": "astro dev --port 8811 --host css-bp.localhost",
    "dev:network": "astro dev --port 8811 --host 0.0.0.0",
    "build": "astro build",
    "preview": "astro preview",
    "check": "astro check",
    "check:links": "node scripts/check-links.js --strict",
    "b4push": "bash scripts/run-b4push.sh",
    "generate:css-wisdom": "node scripts/generate-css-wisdom.js",
    "setup:doc-skill": "node scripts/generate-css-wisdom.js && mkdir -p ~/.claude/skills && ln -sfn \"$(pwd)/.claude/skills/css-wisdom\" ~/.claude/skills/css-wisdom && echo 'Symlinked'",
    "dev:tauri": "cargo tauri dev",
    "build:tauri": "pnpm build && cargo tauri build"
  },
  "dependencies": {
    "@astrojs/mdx": "^4.3.0",
    "@astrojs/preact": "^4.1.0",
    "@shikijs/transformers": "^4.0.0",
    "astro": "^5.18.0",
    "clsx": "^2.1.0",
    "diff": "^8.0.3",
    "github-slugger": "^2.0.0",
    "gray-matter": "^4.0.0",
    "mermaid": "^11.14.0",
    "minisearch": "^7.2.0",
    "preact": "^10.26.0",
    "remark-cjk-friendly": "^2.0.1",
    "remark-directive": "^3.0.0",
    "shiki": "^4.0.2",
    "unist-util-visit": "^5.1.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.0",
    "@tailwindcss/vite": "^4.2.0",
    "@types/hast": "^3.0.4",
    "@types/mdast": "^4.0.4",
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.0",
    "pagefind": "^1.4.0",
    "tailwindcss": "^4.2.0",
    "typescript": "^5.9.0"
  }
}
